# 4900101:m0 = 20.0
# 
# ! --- Dark meson masses
# ! pi_v
# 4900111:m0 = 10.0
# ! rho_v
# 4900113:m0 = 25.0
# 
# ! --- Prompt visible decays
# 4900111:mayDecay = on
# 4900111:tau0 = 0.0
# 4900111:oneChannel = 1 1.0 91 1 -1
# 
# 4900113:mayDecay = on
# 4900113:tau0 = 0.0
# 4900113:oneChannel = 1 1.0 91 1 -1

