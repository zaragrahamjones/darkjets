! hiddenvalley.cmnd
! ------------------------------------------------------------
! pp -> dark quarks -> dark shower -> visible dark hadrons
! Pythia8 HiddenValley example card
! ------------------------------------------------------------

! Settings
Beams:idA = 2212
Beams:idB = 2212
Beams:eCM = 13600.
Next:numberCount = 100
Init:showChangedSettings = on      ! list changed settings
Init:showChangedParticleData = off ! list changed particle data
Next:numberShowInfo = 0            ! print event information n times
Next:numberShowProcess = 1         ! print process record n times
Next:numberShowEvent = 0           ! print event record n times

! Standard QCD/QED settings
PartonLevel:ISR = on
PartonLevel:FSR = on
PartonLevel:MPI = on
HadronLevel:Hadronize = on
! Switch off unwanted parts for HV-only simulation.
! Only FSR:
# PartonLevel:ISR = off
# PartonLevel:MPI = off
# HadronLevel:all = off
! Only HV in FSR:
# TimeShower:QCDshower = off
# TimeShower:QEDshowerByQ = off
# TimeShower:QEDshowerByL = off
# TimeShower:QEDshowerByGamma = off

! Hidden Valley PS
Hiddenvalley:FSR = on
HiddenValley:setLambda = on
Hiddenvalley:Lambda = 4.
HiddenValley:pTminFSR = 6.

! Hidden Valley fragmentation process qv -> HV-mesons
Hiddenvalley:alphaOrder = 1 ! turn off for no HV QCD (i.e. QED), turn on for HV QCD
HiddenValley:Ngauge = 3     ! set=1 for no HV QCD (i.e. QED), set=3 for HV QCD
HiddenValley:nFlav = 3
HiddenValley:fragment = on

! Broken QED:
4900022:mayDecay = off      ! turn off for stable dark photon
# 4900022:m0 = 1.           ! turn on for broken QED, with dark photon mass 1 GeV

! Revert to old 
# TimeShower:recoilStrategyRF = 1

